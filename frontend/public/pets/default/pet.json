{
  "id": "default-pet",
  "name": "Swag Pet",
  "version": "1.0.0",
  "style": "pixel",
  "animations": {
    "idle": {
      "fps": 3,
      "loop": true,
      "frames": ["animations/idle/0.svg", "animations/idle/1.svg"]
    },
    "walk": {
      "fps": 4,
      "loop": true,
      "frames": ["animations/walk/0.svg", "animations/walk/1.svg"]
    },
    "sleep": {
      "fps": 2,
      "loop": true,
      "frames": ["animations/sleep/0.svg", "animations/sleep/1.svg"]
    },
    "happy": {
      "fps": 6,
      "loop": false,
      "frames": ["animations/happy/0.svg", "animations/happy/1.svg", "animations/happy/2.svg"]
    },
    "tap": {
      "fps": 8,
      "loop": false,
      "frames": ["animations/tap/0.svg", "animations/tap/1.svg", "animations/tap/2.svg"]
    }
  }
}
