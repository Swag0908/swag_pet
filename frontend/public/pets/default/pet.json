{
  "id": "default-pet",
  "name": "Swag Pet",
  "version": "1.0.0",
  "style": "pixel",
  "spritesheet": {
    "path": "spritesheet.png",
    "frameWidth": 256,
    "frameHeight": 256,
    "columns": 4,
    "rows": 5
  },
  "animations": {
    "idle": {
      "fps": 3,
      "loop": true,
      "frames": [0, 1, 2, 3]
    },
    "walk": {
      "fps": 4,
      "loop": true,
      "frames": [4, 5, 6, 7]
    },
    "sleep": {
      "fps": 2,
      "loop": true,
      "frames": [8, 9, 10, 11]
    },
    "happy": {
      "fps": 6,
      "loop": false,
      "frames": [12, 13, 14, 15]
    },
    "tap": {
      "fps": 8,
      "loop": false,
      "frames": [16, 17, 18, 19]
    }
  }
}
