{
  "name": "swag-pet",
  "version": "0.1.0",
  "description": "A local desktop pixel pet companion for macOS-first V1.",
  "main": "dist-electron/main/main.js",
  "private": true,
  "license": "GPL-3.0-or-later",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "npm run typecheck && npm run build:main && vite build",
    "build:main": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "start": "npm run build && electron .",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
